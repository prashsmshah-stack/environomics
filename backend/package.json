{
  "name": "environomics-payload-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "seed:home": "payload run src/scripts/seedHomePage.ts",
    "seed:projects": "payload run src/scripts/seedProjects.ts",
    "seed:clients": "payload run src/scripts/seedClients.ts",
    "seed:testimonials": "payload run src/scripts/seedTestimonials.ts",
    "seed:site-sections": "payload run src/scripts/seedSiteSections.ts",
    "seed:all": "npm run seed:home && npm run seed:projects && npm run seed:clients && npm run seed:testimonials && npm run seed:site-sections",
    "audit:content": "payload run src/scripts/auditContent.ts"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "graphql": "^16.12.0",
    "next": "^16.2.6",
    "payload": "^3.84.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
