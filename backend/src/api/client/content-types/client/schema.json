{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client",
    "description": "Client logos shown on the Our Clients page"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "displayOrder": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "isVisible": {
      "type": "boolean",
      "required": true,
      "default": true
    }
  }
}
