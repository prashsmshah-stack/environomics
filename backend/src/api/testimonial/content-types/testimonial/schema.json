{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Client testimonial certificates shown on the Testimonials page"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "companyName": {
      "type": "string",
      "required": true
    },
    "tag": {
      "type": "string",
      "required": false
    },
    "displayOrder": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "isVisible": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "filePageNumber": {
      "type": "integer",
      "required": false,
      "min": 1
    }
  }
}
