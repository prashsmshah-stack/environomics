{
  "kind": "singleType",
  "collectionName": "contact_pages",
  "info": {
    "singularName": "contact-page",
    "pluralName": "contact-pages",
    "displayName": "Contact Page",
    "description": "Contact page content"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "pageName": {
      "type": "string",
      "required": true,
      "default": "Contact Us"
    },
    "heroSection": {
      "type": "component",
      "repeatable": false,
      "component": "contact.hero-section"
    },
    "ctaCards": {
      "type": "component",
      "repeatable": true,
      "component": "contact.cta-card"
    },
    "inquirySection": {
      "type": "component",
      "repeatable": false,
      "component": "contact.inquiry-section"
    },
    "contactDetails": {
      "type": "component",
      "repeatable": false,
      "component": "contact.contact-details"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "common.social-link"
    },
    "officeSection": {
      "type": "component",
      "repeatable": false,
      "component": "contact.office-section"
    },
    "mapSection": {
      "type": "component",
      "repeatable": false,
      "component": "contact.map-section"
    },
    "supportSection": {
      "type": "component",
      "repeatable": false,
      "component": "contact.support-section"
    }
  }
}
